# Copy to .env and set real values. .env is git-ignored.

# Shared JWT signing secret — used by ALL services to sign/verify tokens.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET=change-me-to-a-long-random-value

# PostgreSQL credentials (docker-compose).
POSTGRES_USER=app
POSTGRES_PASSWORD=app

# First-run superuser, created/promoted on Auth startup so you can reach the
# admin panels immediately. Set a strong value (the registration password
# policy — min 8 chars, must not contain the e-mail — is a good floor) and
# change it before any real deployment.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password

# Rate limiting (optional — sensible defaults are baked in). Budgets are per
# client IP per window. RATE_LIMIT_ENABLED=false disables all limits (load
# tests / local debugging only).
#RATE_LIMIT_ENABLED=true
#RATE_LIMIT_WINDOW_SECONDS=60
#LOGIN_RATE_LIMIT=10
#REGISTER_RATE_LIMIT=5
#UPLOAD_RATE_LIMIT=20

# CORS is deny-by-default: the server-rendered UI is same-origin, so no
# cross-origin browser access is granted unless origins are listed here
# (comma-separated) — e.g. a future SPA frontend's URL.
#CORS_ALLOW_ORIGINS=https://frontend.example.com
